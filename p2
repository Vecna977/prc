1.#Load the data
import pandas as pd
file=pd.read_csv("/irisexcel.csv")
x=file[["sepal_length","sepal_width","petal_length","petal_width"]]
y=file["species"]

2.#load the model
from sklearn.linear_model import Perceptron
model=Perceptron()

3.#fit into the model
model.fit(x,y)

4.#predict...testing
op=model.predict([[1.9,2.2,3.3,1.1]])
print(op)
